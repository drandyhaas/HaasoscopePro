	component lvds10 is
		port (
			rx_in         : in  std_logic_vector(11 downto 0)  := (others => 'X'); -- export
			rx_out        : out std_logic_vector(119 downto 0);                    -- export
			rx_coreclock  : out std_logic;                                         -- export
			inclock       : in  std_logic                      := 'X';             -- export
			pll_areset    : in  std_logic                      := 'X';             -- export
			rx_dpa_locked : out std_logic_vector(11 downto 0);                     -- export
			pll_locked    : out std_logic                                          -- export
		);
	end component lvds10;

